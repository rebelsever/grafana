    {
      "id": 11,
      "type": "bargauge",
      "title": "Лучшие кандидаты на кеширование (GET/HEAD, с учетом трафика × latency)",
      "datasource": "$DS_PROMETHEUS",
      "description": "Read-endpoint'ы с наибольшей стоимостью ответа с учетом трафика. Сильные кандидаты на Redis в первую очередь.",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 6,
        "h": 10
      },
      "targets": [
        {
          "expr": "topk($topn,\n(\n  sum by (uri, method) (rate(http_server_requests_seconds_count{job=~\"$job_app\",uri!~\".*actuator.*\",method=~\"GET|HEAD\"}[$__rate_interval]))\n  *\n  (\n    sum by (uri, method) (rate(http_server_requests_seconds_sum{job=~\"$job_app\",uri!~\".*actuator.*\",method=~\"GET|HEAD\"}[$__rate_interval]))\n    /\n    clamp_min(sum by (uri, method) (rate(http_server_requests_seconds_count{job=~\"$job_app\",uri!~\".*actuator.*\",method=~\"GET|HEAD\"}[$__rate_interval])), 0.000001)\n  )\n)\n)",
          "refId": "A",
          "instant": true,
          "legendFormat": "{{method}} {{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": false,
        "minVizHeight": 12,
        "minVizWidth": 0
      }
    },
