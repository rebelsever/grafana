    {
      "id": 15,
      "type": "table",
      "title": "Current long-running SQL sessions",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRESQL}"
      },
      "description": "Live snapshot from pg_stat_activity. Useful during an incident.",
      "gridPos": {
        "x": 0,
        "y": 26,
        "w": 12,
        "h": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRESQL}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  pid,\n  usename,\n  application_name,\n  state,\n  COALESCE(wait_event_type, '') AS wait_type,\n  COALESCE(wait_event, '') AS wait_event,\n  ROUND(EXTRACT(EPOCH FROM (now() - query_start))::numeric, 1) AS runtime_s,\n  LEFT(REGEXP_REPLACE(query, E'[\\n\\r\\t ]+', ' ', 'g'), 180) AS query\nFROM pg_stat_activity\nWHERE pid <> pg_backend_pid()\n  AND state <> 'idle'\n  AND query IS NOT NULL\n  AND query NOT ILIKE '%pg_stat_activity%'\nORDER BY now() - query_start DESC\nLIMIT 15;",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ]
        }
      }
    },
    {
      "id": 16,
      "type": "table",
      "title": "Current wait events summary",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRESQL}"
      },
      "description": "Live wait profile from pg_stat_activity.",
      "gridPos": {
        "x": 12,
        "y": 26,
        "w": 6,
        "h": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRESQL}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(wait_event_type, 'Running/CPU') AS wait_type,\n  COALESCE(wait_event, '') AS wait_event,\n  COUNT(*) AS sessions\nFROM pg_stat_activity\nWHERE pid <> pg_backend_pid()\nGROUP BY 1, 2\nORDER BY sessions DESC, wait_type, wait_event\nLIMIT 15;",
          "refId": "A"
        }
