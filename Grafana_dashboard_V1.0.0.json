      "title": "Top hot tables by sequential scans",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRESQL}"
      },
      "description": "Current cumulative table access pattern from pg_stat_user_tables.",
      "gridPos": {
        "x": 0,
        "y": 35,
