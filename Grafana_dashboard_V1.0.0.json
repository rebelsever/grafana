    {
      "id": 13,
      "type": "bargauge",
      "title": "Slowest methods by p95 latency",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Endpoints with the worst tail latency over the selected time range.",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 6,
        "h": 10
      },
      "targets": [
        {
          "expr": "topk($topn,\nhistogram_quantile(\n  0.95,\n  sum by (uri, method, le) (rate(http_server_requests_seconds_bucket{job=~\"$job_app\",uri!~\".*actuator.*\"}[$__rate_interval]))\n)\n)",
