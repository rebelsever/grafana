    {
      "id": 9,
      "type": "table",
      "title": "Top methods by RPS",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Top endpoints by request rate.",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 15
      },
      "targets": [
        {
          "expr": "topk(15, sum by (uri, method) (rate(http_server_requests_seconds_count{job=~\"$job_app\",uri=~\"$uri\",method=~\"$method\",status=~\"$status\",uri!~\".*actuator.*\"}[$__rate_interval])))",
          "refId": "A",
          "instant": true,
          "legendFormat": "__auto"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ]
        },
        "sortBy": [
          {
            "displayName": "Value",
            "desc": true
          }
        ]
      }
    },
    {
